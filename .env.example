# ── Telegram bot (OPTIONAL / 可选) ──
# Only needed for the optional Telegram bot front-end (`npm start`).
# The CLI (`echocut burn ...`) does NOT need these — leave empty if you only use the CLI.
# 仅在使用可选的 Telegram bot 前端时需要;只用 CLI 的话留空即可。
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# 文案生成模型名称（2G 云服务器建议仅做远端调用，不在本机跑大模型）
OLLAMA_MODEL=qwen3.5:9b
# Ollama API 地址（2G 云服务器建议指向外部高配 Ollama）
OLLAMA_URL=http://127.0.0.1:11434/api/chat
# Ollama 请求超时（毫秒），网络较慢时可调大
OLLAMA_TIMEOUT_MS=300000
# Ollama 重试次数，抖动场景建议 2~3
OLLAMA_RETRIES=2

# 网络代理（按需开启；无需代理可留空）
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
ALL_PROXY=socks5://127.0.0.1:7897
# 代理白名单（本地服务走直连）
NO_PROXY=127.0.0.1,localhost

# Python 可执行路径（默认优先使用项目 .venv）
PYTHON_BIN=.venv/bin/python
# WhisperX 转写脚本路径
TRANSCRIBE_SCRIPT_PATH=transcribe.py
# MLX 转写脚本路径（仅 Apple Silicon 有效）
TRANSCRIBE_MLX_SCRIPT_PATH=transcribe_mlx.py
# FunASR 转写脚本路径
TRANSCRIBE_FUNASR_SCRIPT_PATH=transcribe_funasr.py
# 转写引擎：auto / whisperx / mlx / funasr（Linux 推荐 whisperx）
TRANSCRIBE_ENGINE=auto
# ASR 路由档位：hq / fast（仅影响默认模型选择）
ASR_PROFILE=hq

# WhisperX 模型（低内存机器建议 small；高配可用 medium/large-v3）
WHISPERX_MODEL=large-v3
# WhisperX 失败回退模型（逗号分隔，按顺序尝试）
WHISPERX_MODEL_FALLBACKS=medium,small
# WhisperX 高精模型（engine=whisperx_hq 时使用）
WHISPERX_HQ_MODEL=large-v3
# 低内存模式：1 开启（自动降模型与批次，2G 云主机建议开启）
WHISPERX_LOW_MEMORY=0
# 转写批次（低内存建议 1）
WHISPERX_BATCH_SIZE=4
# 是否关闭词级对齐（1=关闭，能显著降低内存占用）
WHISPERX_DISABLE_ALIGN=0
# 单次转写超时（毫秒）
TRANSCRIBE_TIMEOUT_MS=900000
# MLX 快速模型（engine=mlx 时默认）
MLX_WHISPER_FAST_MODEL=mlx-community/whisper-large-v3-turbo
# MLX 高精模型（engine=mlx_hq 或 auto@macOS 时默认）
MLX_WHISPER_HQ_MODEL=mlx-community/whisper-large-v3
# MLX 指定模型（可填逗号分隔，脚本按顺序回退）
MLX_WHISPER_MODEL=mlx-community/whisper-large-v3,mlx-community/whisper-large-v3-turbo
# FunASR 默认模型（中文优先推荐 paraformer-zh）
FUNASR_MODEL=paraformer-zh
# SenseVoice 模型（支持逗号回退，效果优先可尝试 iic/SenseVoiceLarge）
FUNASR_SENSEVOICE_MODEL=iic/SenseVoiceSmall,iic/SenseVoiceLarge
# FunASR 设备（cpu/mps/cuda；Apple Silicon 建议 mps）
FUNASR_DEVICE=mps

# 任务并发（稳定优先建议 1；本地压测再逐步升到 2~3）
TASK_QUEUE_CONCURRENCY=1
# 下载超时（毫秒），大视频/弱网可调大
DOWNLOAD_TIMEOUT_MS=120000
# 下载失败重试次数（502/超时等会自动重试）
DOWNLOAD_RETRIES=3
# 下载重试间隔基准（毫秒），实际会按次数递增
DOWNLOAD_RETRY_DELAY_MS=1200
# 视频链路模式：fast(并行全流程并提前反馈) / full(完整串行反馈)
VIDEO_CONTENT_MODE=fast
# Bot 网络重试次数（代理抖动/切 IP 建议 3~5）
BOT_NETWORK_RETRIES=3
# Bot 网络重试间隔基准（毫秒），实际会按次数递增并带随机抖动
BOT_NETWORK_RETRY_DELAY_MS=1200
# Bot 发送最小间隔（毫秒），降低 Telegram 429 风险
BOT_SEND_MIN_INTERVAL_MS=450
# 遇到 Telegram 429 时单次消息最大重试次数
BOT_429_MAX_RETRIES=6
# Remotion 渲染缩放（低配机器建议 0.75）
REMOTION_SCALE=1
# Remotion 并发（低配机器建议 1）
REMOTION_CONCURRENCY=0

# 管理后台端口
ADMIN_PORT=3399
# Telegram 轮询节奏（网络抖动可调大）
TELEGRAM_POLLING_INTERVAL_MS=700
TELEGRAM_POLLING_TIMEOUT_SEC=25
# 守护进程重启基础延迟（毫秒）
APP_WATCHDOG_RESTART_DELAY_MS=1500
# 守护进程重启最大延迟（毫秒）
APP_WATCHDOG_MAX_RESTART_DELAY_MS=30000
# 守护进程重启随机抖动（毫秒）
APP_WATCHDOG_RESTART_JITTER_MS=800

# ---------------- MiniMax 云端能力（可选，本地能力不够时兜底） ----------------
# 申请地址：https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=
# Base URL，国内可用 https://api.minimaxi.com，备用 https://api-bj.minimaxi.com
MINIMAX_BASE_URL=https://api.minimaxi.com
# TTS HD 模型：speech-2.8-hd / speech-2.6-hd / speech-02-hd
MINIMAX_TTS_MODEL=speech-2.6-hd
# 文生视频模型：MiniMax-Hailuo-2.3 / MiniMax-Hailuo-2.3-Fast / MiniMax-Hailuo-02
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3-Fast
# 图像模型：image-01 / image-01-live
MINIMAX_IMAGE_MODEL=image-01
# 音乐模型：music-2.6 / music-2.5 / music-cover
MINIMAX_MUSIC_MODEL=music-2.6
# 文本/推理模型：统一用 MiniMax-M2.7（新套餐，不再用 *-highspeed 后缀）
MINIMAX_TEXT_MODEL=MiniMax-M2.7
# 每日 MiniMax 调用次数预算护栏（0 = 不限制）
MINIMAX_DAILY_BUDGET=0
